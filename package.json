{
  "name": "@quantum-native/quantum-chess-sdk",
  "version": "0.2.1",
  "type": "module",
  "license": "MIT",
  "description": "Player SDK for building Quantum Chess AIs — match runner, explorer, tournament system, reference AI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quantum-native/quantum-chess-sdk.git"
  },
  "homepage": "https://quantumchess.net",
  "keywords": [
    "quantum-chess",
    "chess",
    "quantum",
    "ai",
    "sdk",
    "game-engine",
    "tournament"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist --clean",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@quantum-native/quantum-forge-chess": "^1.11.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  }
}
